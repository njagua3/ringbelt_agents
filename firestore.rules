rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: properties
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, 3-100 chars)
    //   - location: string (required, 3-100 chars)
    //   - price: string (required, 1-50 chars)
    //   - image: string (required, valid URL)
    //   - category: string (required, enum)
    //   - available: bool (required)
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "kevin.nyingi@student.moringaschool.com" && request.auth.token.email_verified == true);
    }

    function isValidProperty(data) {
      return data.keys().hasAll(['title', 'location', 'price', 'image', 'category', 'available', 'createdAt', 'updatedAt']) &&
             data.title is string && data.title.size() >= 3 && data.title.size() <= 100 &&
             data.location is string && data.location.size() >= 3 && data.location.size() <= 100 &&
             data.price is string && data.price.size() >= 1 && data.price.size() <= 50 &&
             data.image is string && data.image.matches("^https?://.*") &&
             data.category in ['1 Bedroom', '2 Bedroom', 'Bedsitters', 'Single Rooms', 'Student Hostels', 'Business Shops', 'Commercial Spaces', 'Premium Properties'] &&
             data.available is bool &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    match /properties/{propertyId} {
      allow read: if true; // Public listings
      allow create: if isAdmin() && isValidProperty(request.resource.data);
      allow update: if isAdmin() && isValidProperty(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
